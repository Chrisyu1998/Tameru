# Tameru frontend — Vite env vars.
# All VITE_* vars are exposed to the client bundle. No secrets here.
# Copy to .env.local for local dev (.env.local is gitignored).

# Backend API base URL.
#   local dev:       http://localhost:8000
#   production:      https://api.tameru.app
VITE_API_URL=http://localhost:8000

# Supabase — client-safe (anon key is RLS-scoped, used with the user's JWT).
# Day 6 does not consume these yet; Day 7 wires up the Supabase JS client.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PostHog (Day 26 — DESIGN.md §9.5). Region pinned to US Cloud; EU Cloud +
# GDPR-consent flow is a §17 scaling-plan deliverable, not v1. Both vars
# are client-safe — the project key is publishable and PostHog ingest is
# scoped by it. Leaving these blank disables analytics entirely (the SDK
# init no-ops, see lib/analytics.ts).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
