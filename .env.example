# Tameru — environment variables.
# Copy to .env and fill in. .env is gitignored; never commit real values.
# Secrets live only here and in Railway's env UI (DESIGN.md §9.2).

# --- Supabase ---------------------------------------------------------------
# URL + anon key are client-safe and used by the FastAPI per-request client
# that forwards the user's JWT so Postgres enforces RLS (CLAUDE.md #1).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key: pg_cron and Supabase CLI migrations ONLY. Never in handlers.
SUPABASE_SERVICE_ROLE_KEY=
# User JWT verification (app/auth.py) uses this project's asymmetric JWKS at
# {SUPABASE_URL}/auth/v1/.well-known/jwks.json — nothing else to configure.

# --- AI providers -----------------------------------------------------------
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Gemini model resolution (app/integrations/gemini.py::_model_name).
# No hardcoded fallback — at least one of these must be set, else the
# categorize() path raises GeminiProviderError on first call.
#   GEMINI_MODEL          — per-process override. Leave unset in prod;
#                           set to the preview model for eval experiments.
#   GEMINI_MODEL_DEFAULT  — platform-level default. Set this to the
#                           stable GA model. Operators rotate this (no
#                           code change) when the chosen model is
#                           deprecated or unstable.
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_MODEL_DEFAULT=gemini-2.5-flash
# Gemini's API enforces a 10s minimum deadline; smaller values return
# INVALID_ARGUMENT. Code clamps up to 10 if a smaller value is set.
GEMINI_TIMEOUT_S=10
# (PERPLEXITY_API_KEY removed — card lookup now goes through Claude `web_search`
#  on the existing ANTHROPIC_API_KEY. See DESIGN.md §0, §6.1, and Day 14.)

# --- CSV import (Day 20) ----------------------------------------------------
# HMAC secret signing the stateless `import_token` that threads state from
# /imports/csv/preview to /imports/csv/commit. The two endpoints don't
# persist the uploaded file between calls (DESIGN.md §5.4.3) — verification
# is "the user re-uploaded the same bytes" via file_hash inside the token.
# Required. Rotate to invalidate all in-flight tokens. Any random string ≥32
# chars is fine; production sets this in Railway's env UI.
IMPORT_TOKEN_SECRET=

# --- Email ------------------------------------------------------------------
RESEND_API_KEY=

# --- Frontend origin (CORS allowlist) ---------------------------------------
# FastAPI's CORSMiddleware (app/main.py) always allows http://localhost:5173
# for the Vite dev server. Set FRONTEND_ORIGIN in Railway to the production
# Vercel domain (e.g. https://tameru.app) to add it to the allowlist.
# Leave unset in local dev. No wildcards — any Vercel tenant would reach the
# API otherwise (DESIGN.md §5.3, §9.3).
# FRONTEND_ORIGIN=https://tameru.app

# --- MCP server (Day 23) ----------------------------------------------------
# The read-only MCP server (app/mcp_server.py) is an OAuth 2.1 Resource
# Server; auth is delegated to Supabase Auth's OAuth 2.1 Server (see
# supabase/MCP_OAUTH_SETUP.md). This is the MCP endpoint's public URL,
# advertised in the protected-resource metadata MCP clients discover.
# Required — the backend refuses to boot without it (app/main.py).
# Local dev: http://localhost:8000/mcp
MCP_RESOURCE_SERVER_URL=

# --- Observability ----------------------------------------------------------
SENTRY_DSN=

# --- Product analytics (PostHog) --------------------------------------------
# Structural events only — never send transaction amounts, merchant names,
# card details, or chat text (CLAUDE.md privacy posture).
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
