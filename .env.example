# Tameru — environment variables.
# Copy to .env and fill in. .env is gitignored; never commit real values.
# Secrets live only here and in Railway's env UI (DESIGN.md §9.2).

# --- Supabase ---------------------------------------------------------------
# URL + anon key are client-safe and used by the FastAPI per-request client
# that forwards the user's JWT so Postgres enforces RLS (CLAUDE.md #1).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key: pg_cron and Supabase CLI migrations ONLY. Never in handlers.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI providers -----------------------------------------------------------
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Default model is gemini-3.1-flash-lite-preview; override to fall back to
# gemini-2.5-flash if the preview becomes unstable (CLAUDE.md model table).
GEMINI_MODEL=gemini-3.1-flash-lite-preview
PERPLEXITY_API_KEY=

# --- Email ------------------------------------------------------------------
RESEND_API_KEY=

# --- Observability ----------------------------------------------------------
SENTRY_DSN=

# --- Product analytics (PostHog) --------------------------------------------
# Structural events only — never send transaction amounts, merchant names,
# card details, or chat text (CLAUDE.md privacy posture).
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
