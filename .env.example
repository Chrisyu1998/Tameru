# Tameru — environment variables.
# Copy to .env and fill in. .env is gitignored; never commit real values.
# Secrets live only here and in Railway's env UI (DESIGN.md §9.2).

# --- Supabase ---------------------------------------------------------------
# URL + anon key are client-safe and used by the FastAPI per-request client
# that forwards the user's JWT so Postgres enforces RLS (CLAUDE.md #1).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key. Required by:
#   - pg_cron jobs and CLI migrations (always have been).
#   - The §6.4 weekly digest cron (`app/cron/digest.py`).
#   - The web process: /unsubscribe and /webhooks/resend both call
#     supabase_admin() because their inbound requests carry no user
#     JWT (CLAUDE.md invariant 1 sanctioned callers #3 and #4).
# Application request handlers that DO carry a user JWT must never
# use this — the leak test enforces that boundary.
SUPABASE_SERVICE_ROLE_KEY=
# User JWT verification (app/auth.py) uses this project's asymmetric JWKS at
# {SUPABASE_URL}/auth/v1/.well-known/jwks.json — nothing else to configure.

# --- AI providers -----------------------------------------------------------
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Gemini model resolution (app/integrations/gemini.py::_model_name).
# No hardcoded fallback — at least one of these must be set, else the
# categorize() path raises GeminiProviderError on first call.
#   GEMINI_MODEL          — per-process override. Leave unset in prod;
#                           set to the preview model for eval experiments.
#   GEMINI_MODEL_DEFAULT  — platform-level default. Set this to the
#                           stable GA model. Operators rotate this (no
#                           code change) when the chosen model is
#                           deprecated or unstable.
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_MODEL_DEFAULT=gemini-2.5-flash
# Gemini's API enforces a 10s minimum deadline; smaller values return
# INVALID_ARGUMENT. Code clamps up to 10 if a smaller value is set.
GEMINI_TIMEOUT_S=10
# (PERPLEXITY_API_KEY removed — card lookup now goes through Claude `web_search`
#  on the existing ANTHROPIC_API_KEY. See DESIGN.md §0, §6.1, and Day 14.)

# --- CSV import (Day 20) ----------------------------------------------------
# HMAC secret signing the stateless `import_token` that threads state from
# /imports/csv/preview to /imports/csv/commit. The two endpoints don't
# persist the uploaded file between calls (DESIGN.md §5.4.3) — verification
# is "the user re-uploaded the same bytes" via file_hash inside the token.
# Required. Rotate to invalidate all in-flight tokens. Any random string ≥32
# chars is fine; production sets this in Railway's env UI.
IMPORT_TOKEN_SECRET=

# --- Email + weekly digest (Day 25, DESIGN.md §6.4) -------------------------
# Resend SDK API key for the digest cron and any future scheduled email.
# Required by the cron at `python -m app.cron.digest`. NOT required by the
# request-serving process — the web boot check omits it deliberately so a
# cron-only env doesn't crash the API.
RESEND_API_KEY=

# Svix signing secret for /webhooks/resend (bounce + complaint events).
# Required by the request-serving process. Find it in Resend dashboard →
# Webhooks → your endpoint → "Signing Secret" (starts with `whsec_`).
RESEND_WEBHOOK_SECRET=

# HMAC key for one-click List-Unsubscribe tokens minted by the cron and
# verified by /unsubscribe. Stateless — no DB lookup, no expiry. Rotate to
# invalidate every live unsubscribe link (the right property if it leaks).
# 32 random bytes, base64 — generate with `openssl rand -base64 32`.
DIGEST_UNSUBSCRIBE_SECRET=

# Optional override for the Sonnet model used by the §6.4 narrative call.
# v1 default `claude-sonnet-4-6` (no env needed in prod). Kept separate from
# ANTHROPIC_MODEL (chat agent) so a chat-side downgrade doesn't drag the
# digest down with it. CLAUDE.md "Model usage by task".
# ANTHROPIC_DIGEST_MODEL=

# Optional sender identity overrides. Defaults `"Tameru" <hello@mail.tameru.xyz>`
# and reply-to `hello@mail.tameru.xyz`. mail.tameru.xyz must have SPF/DKIM/DMARC
# configured in Resend's dashboard before the first real send (DESIGN.md §6.4).
# RESEND_FROM=
# RESEND_REPLY_TO=

# --- Public hostnames -------------------------------------------------------
# Public URL of this Railway backend (e.g. https://tameru-production.up.railway.app).
# Required by the web process. The digest cron embeds it in every email's
# List-Unsubscribe URL — distinct from FRONTEND_ORIGIN because /unsubscribe is
# a FastAPI route, not an SPA route; Vercel's catch-all would otherwise serve
# index.html and Gmail's one-click POSTs would never reach the handler.
BACKEND_PUBLIC_URL=

# --- Frontend origin (CORS allowlist) ---------------------------------------
# FastAPI's CORSMiddleware (app/main.py) always allows http://localhost:5173
# for the Vite dev server. Set FRONTEND_ORIGIN in Railway to the production
# Vercel domain (e.g. https://tameru.xyz) to add it to the allowlist.
# Leave unset in local dev. No wildcards — any Vercel tenant would reach the
# API otherwise (DESIGN.md §5.3, §9.3).
# FRONTEND_ORIGIN=https://tameru.xyz

# --- MCP server (Day 23) ----------------------------------------------------
# The read-only MCP server (app/mcp_server.py) is an OAuth 2.1 Resource
# Server; auth is delegated to Supabase Auth's OAuth 2.1 Server (see
# supabase/MCP_OAUTH_SETUP.md). This is the MCP endpoint's public URL,
# advertised in the protected-resource metadata MCP clients discover.
# Required — the backend refuses to boot without it (app/main.py).
# Local dev: http://localhost:8000/mcp
MCP_RESOURCE_SERVER_URL=

# --- Observability ----------------------------------------------------------
SENTRY_DSN=

# --- Product analytics (PostHog) --------------------------------------------
# Structural events only — never send transaction amounts, merchant names,
# card details, or chat text (CLAUDE.md privacy posture).
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
